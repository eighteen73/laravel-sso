{
    "name": "eighteen73/laravel-sso",
    "description": "Abstract SSO logic into a reusable, self-contained Laravel package.",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Ed Jeavons",
            "email": "ed@eighteen73.co.uk"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "laravel/socialite": "^5.12",
        "socialiteproviders/zitadel": "^4.2"
    },
    "require-dev": {
        "ergebnis/composer-normalize": "^2.50",
        "laravel/pint": "^1.29",
        "orchestra/testbench": "^10.0 || ^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/phpstan": "^2.1"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Eighteen73\\SSO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eighteen73\\SSO\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eighteen73\\SSO\\SSOServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@composer normalize"
        ],
        "post-require": [
            "@composer normalize"
        ]
    }
}